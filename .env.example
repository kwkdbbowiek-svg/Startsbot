# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=@YourBotUsername

# Database Configuration
DB_HOST=localhost
DB_NAME=telegram_stars_bot
DB_USER=root
DB_PASS=your_database_password

# Web App URL
WEBAPP_URL=https://yourdomain.com/webapp/index.html

# API Keys
FRAGMENT_JWT_TOKEN=your_fragment_jwt_token
SMMUPPER_API_KEY=your_smmupper_api_key

# Channel Settings
CHANNEL_USERNAME=@yourchannel
CHANNEL_ID=-1001234567890

# Manual Payment (Karta ma'lumotlari)
MANUAL_CARD_NUMBER=8600 1234 5678 9012
MANUAL_CARD_HOLDER=YOUR NAME

# Admin User ID (Telegram)
ADMIN_USER_ID=123456789

# Environment (production, development)
APP_ENV=production
APP_DEBUG=false
